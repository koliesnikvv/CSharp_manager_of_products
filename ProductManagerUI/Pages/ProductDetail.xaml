<Page x:Class="ProductManagerUI.Pages.ProductDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Деталі товару">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Information about the product" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
                <StackPanel>
                    <TextBlock x:Name="ProductNameText" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="CategoryText" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock x:Name="PriceText" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock x:Name="AmountText" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DescriptionText" FontSize="14" FontStyle="Italic" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="Back to the list" Click="Back_Click" Margin="0,20,0,0" Width="120" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Page>