<Page x:Class="ProductManagerUI.Pages.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Product Details">

    <Grid Background="#F5F5F5">
        <StackPanel Margin="30" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="{Binding Name}" FontSize="32" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding Category}" FontSize="18" Foreground="#7F8C8D" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="16" Margin="0,5">
                        <Run Text="Price: " FontWeight="Bold"/>
                        <Run Text="{Binding PricePerItem, StringFormat='{}{0:N2} UAH'}"/>
                    </TextBlock>
                    <TextBlock FontSize="16" Margin="0,5">
                        <Run Text="Quantity in Stock: " FontWeight="Bold"/>
                        <Run Text="{Binding Quantity}"/>
                    </TextBlock>
                    <TextBlock FontSize="16" Margin="0,5">
                        <Run Text="Total Value: " FontWeight="Bold"/>
                        <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat='{}{0:N2} UAH'}"/>
                    </TextBlock>

                    <Separator Margin="0,15"/>

                    <TextBlock Text="Description:" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Description}" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <Button Content="← Back to List" Click="Back_Click" Width="150" Height="35" Margin="0,30,0,0" 
                    HorizontalAlignment="Left" Background="#34495E" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>