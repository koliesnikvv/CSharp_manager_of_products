<Page x:Class="ProductManagerUI.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="MainPage">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Select Warehouse (Level 1 Entities)" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>

            <ListBox x:Name="WarehouseListBox" 
                     FontSize="18" 
                     ItemsSource="{Binding Depositories}" 
                     SelectionChanged="WarehouseListBox_SelectionChanged">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="10" 
                                Margin="5">
                            <TextBlock Text="{Binding Name}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>