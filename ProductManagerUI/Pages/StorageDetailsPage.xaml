<Page x:Class="ProductManagerUI.Pages.StorageDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StorageDetails">

    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="{Binding Storage.Name}" FontSize="24" Margin="10"/>
            <TextBlock Text="{Binding Storage.Location}" Margin="10,0,10,10"/>

            <ListBox ItemsSource="{Binding Storage.Products}" 
                     x:Name="ProductsListBox" 
                     Height="300"
                     SelectionChanged="ProductsListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Back" Click="Back_Click" Width="100" Margin="10" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Page>